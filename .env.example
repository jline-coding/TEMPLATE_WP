# ═══════════════════════════════════════════════════════════════
#  🇯🇵 環境設定 | 🇻🇳 Cấu hình môi trường | 🇬🇧 Environment Settings
# ═══════════════════════════════════════════════════════════════
#
#  PROXY_URL : BrowserSync がプロキシするローカルサーバーのURL
#              URL mà BrowserSync sẽ proxy tới
#              The local server URL that BrowserSync will proxy to
#
#  WEB_ROOT  : ローカルサーバーのドキュメントルート (symlink作成先)
#              Thư mục gốc của local server (nơi tạo symlink)
#              Local server's document root (symlink target)
#
# ─────────────────────────────────────────────────────────────

PROXY_URL=my-project.test
WEB_ROOT=D:\laragon\www

# ═══════════════════════════════════════════════════════════════
#  🇯🇵 設定例 | 🇻🇳 Ví dụ cấu hình | 🇬🇧 Configuration Examples
# ═══════════════════════════════════════════════════════════════
#
# ┌─────────────────────────────────────────────────────────────
# │ 🖥️  Windows + Laragon
# │
# │  PROXY_URL=my-project.test
# │  WEB_ROOT=D:\laragon\www
# │
# │  → BrowserSync: http://localhost:3000 → http://my-project.test
# │  → phpMyAdmin: http://localhost/phpmyadmin
# └─────────────────────────────────────────────────────────────
#
# ┌─────────────────────────────────────────────────────────────
# │ 🖥️  Windows + XAMPP
# │
# │  PROXY_URL=localhost/my-project
# │  WEB_ROOT=C:\xampp\htdocs
# │
# │  → BrowserSync: http://localhost:3000 → http://localhost/my-project
# │  → phpMyAdmin: http://localhost/phpmyadmin
# └─────────────────────────────────────────────────────────────
#
# ┌─────────────────────────────────────────────────────────────
# │ 🍎  macOS + MAMP
# │
# │  PROXY_URL=localhost:8888/my-project
# │  WEB_ROOT=/Applications/MAMP/htdocs
# │
# │  → BrowserSync: http://localhost:3000 → http://localhost:8888/my-project
# │  → phpMyAdmin: http://localhost:8888/phpMyAdmin
# │  → WP Database Host: localhost:8889
# └─────────────────────────────────────────────────────────────
#
# ┌─────────────────────────────────────────────────────────────
# │ 🍎  macOS + Laravel Valet
# │
# │  PROXY_URL=my-project.test
# │  WEB_ROOT=/Users/[username]/.valet/Sites
# │
# │  → Sau khi setup: cd public && valet link my-project
# └─────────────────────────────────────────────────────────────
#
# ┌─────────────────────────────────────────────────────────────
# │ 🐧  Linux + Apache
# │
# │  PROXY_URL=localhost/my-project
# │  WEB_ROOT=/var/www/html
# │
# │  → Cần sudo cho npm run link nếu không có quyền ghi
# └─────────────────────────────────────────────────────────────
