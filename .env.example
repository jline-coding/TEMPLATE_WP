# ─────────────────────────────────────────────
# Server Settings
# ─────────────────────────────────────────────

# Loại Server của bạn / Your server type
# Giá trị hợp lệ / Valid values: laragon | xampp | mamp | valet
SERVER_TYPE=laragon

# ─────────────────────────────────────────────
# Web Root — đường dẫn thư mục web của server
# ─────────────────────────────────────────────
# Mỗi SERVER_TYPE có đường dẫn mặc định (auto-detect),
# chỉ cần set WEB_ROOT nếu khác với mặc định.
#
#   laragon → D:\laragon\www              (Windows)
#   xampp   → C:\xampp\htdocs             (Windows)
#   mamp    → /Applications/MAMP/htdocs   (macOS)
#   valet   → ~/.valet/Sites              (macOS)
#   (linux) → /var/www/html               (Linux)
#
# Ví dụ / Examples:
#   WEB_ROOT=D:\laragon\www
#   WEB_ROOT=/Applications/MAMP/htdocs
#   WEB_ROOT=/var/www/html

# WEB_ROOT=

# ─────────────────────────────────────────────
# Proxy URL (optional)
# ─────────────────────────────────────────────
# Nếu không đặt, sẽ tự sinh theo SERVER_TYPE:
#   laragon → http://[project_name].test
#   xampp   → http://localhost/[project_name]
#   mamp    → http://localhost:8888/[project_name]
#   valet   → http://[project_name].test
#
# Đặt giá trị tuỳ chỉnh nếu cần:
# PROXY_URL=http://myproject.local
