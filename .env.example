# ═══════════════════════════════════════════════════════════════
#  🇯🇵 サーバー設定 | 🇻🇳 Cấu hình Server | 🇬🇧 Server Settings
# ═══════════════════════════════════════════════════════════════
#
#  🇯🇵 ご使用のサーバーに合わせて SERVER_TYPE と WEB_ROOT を設定してください。
#  🇻🇳 Hãy chọn SERVER_TYPE và WEB_ROOT phù hợp với server bạn đang dùng.
#  🇬🇧 Set SERVER_TYPE and WEB_ROOT to match your local server.
#
#  SERVER_TYPE : laragon | xampp | mamp | valet
#  WEB_ROOT    : サーバーのドキュメントルート / Đường dẫn web root / Server document root
#
# ─────────────────────────────────────────────────────────────

SERVER_TYPE=laragon
# WEB_ROOT=

# ═══════════════════════════════════════════════════════════════
#  🇯🇵 設定例 | 🇻🇳 Ví dụ cấu hình | 🇬🇧 Configuration Examples
# ═══════════════════════════════════════════════════════════════
#
# ┌─────────────────────────────────────────────────────────────
# │ 🖥️  Windows + Laragon
# │
# │  🇯🇵 Laragonのデフォルト設定。.test ドメインが自動的に使用されます。
# │  🇻🇳 Cấu hình mặc định Laragon. Domain .test được tạo tự động.
# │  🇬🇧 Default Laragon setup. The .test domain is auto-generated.
# │
# │  SERVER_TYPE=laragon
# │  WEB_ROOT=D:\laragon\www
# │
# │  → Proxy: http://[project_name].test
# │  → phpMyAdmin: http://localhost/phpmyadmin
# └─────────────────────────────────────────────────────────────
#
# ┌─────────────────────────────────────────────────────────────
# │ 🖥️  Windows + XAMPP
# │
# │  🇯🇵 XAMPPのデフォルト設定。localhost 経由でアクセスします。
# │  🇻🇳 Cấu hình mặc định XAMPP. Truy cập qua localhost.
# │  🇬🇧 Default XAMPP setup. Access via localhost.
# │
# │  SERVER_TYPE=xampp
# │  WEB_ROOT=C:\xampp\htdocs
# │
# │  → Proxy: http://localhost/[project_name]
# │  → phpMyAdmin: http://localhost/phpmyadmin
# └─────────────────────────────────────────────────────────────
#
# ┌─────────────────────────────────────────────────────────────
# │ 🍎  macOS + MAMP
# │
# │  🇯🇵 MAMPのデフォルト設定。Apache: 8888, MySQL: 8889。
# │     WPインストール時のDBホストは localhost:8889 に設定してください。
# │  🇻🇳 Cấu hình mặc định MAMP. Apache: 8888, MySQL: 8889.
# │     Khi cài WP, Database Host phải là localhost:8889.
# │  🇬🇧 Default MAMP setup. Apache: 8888, MySQL: 8889.
# │     When installing WP, set Database Host to localhost:8889.
# │
# │  SERVER_TYPE=mamp
# │  WEB_ROOT=/Applications/MAMP/htdocs
# │
# │  → Proxy: http://localhost:8888/[project_name]
# │  → phpMyAdmin: http://localhost:8888/phpMyAdmin
# └─────────────────────────────────────────────────────────────
#
# ┌─────────────────────────────────────────────────────────────
# │ 🍎  macOS + Laravel Valet
# │
# │  🇯🇵 Valetの設定。.test ドメインが自動に使用されます。
# │     セットアップ後 cd public && valet link [project_name] を実行。
# │  🇻🇳 Cấu hình Valet. Domain .test được tạo tự động.
# │     Sau khi setup, chạy: cd public && valet link [project_name]
# │  🇬🇧 Valet setup. The .test domain is auto-generated.
# │     After setup, run: cd public && valet link [project_name]
# │
# │  SERVER_TYPE=valet
# │  WEB_ROOT=/Users/[username]/.valet/Sites
# │
# │  → Proxy: http://[project_name].test
# └─────────────────────────────────────────────────────────────
#
# ┌─────────────────────────────────────────────────────────────
# │ 🐧  Linux + Apache
# │
# │  🇯🇵 Linux Apache のデフォルト設定。
# │     /var/www/html への書き込みには sudo が必要です。
# │  🇻🇳 Cấu hình mặc định Apache trên Linux.
# │     Cần quyền sudo để ghi vào /var/www/html.
# │  🇬🇧 Default Linux Apache setup.
# │     Requires sudo for write access to /var/www/html.
# │
# │  SERVER_TYPE=laragon
# │  WEB_ROOT=/var/www/html
# │  PROXY_URL=http://localhost/my-project
# │
# │  → phpMyAdmin: http://localhost/phpmyadmin
# └─────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════
#  🇯🇵 Proxy URL（任意）| 🇻🇳 Proxy URL (tuỳ chọn) | 🇬🇧 Proxy URL (optional)
# ═══════════════════════════════════════════════════════════════
#
#  🇯🇵 通常は設定不要。SERVER_TYPE から自動生成されます。
#     カスタムドメインやポートを使用する場合のみ設定してください。
#  🇻🇳 Thường không cần set. Hệ thống tự sinh từ SERVER_TYPE.
#     Chỉ set khi dùng domain hoặc port khác mặc định.
#  🇬🇧 Usually not needed. Auto-generated from SERVER_TYPE.
#     Only set this if you use a custom domain or non-default port.
#
#  🇯🇵 自動生成ルール | 🇻🇳 Quy tắc tự sinh | 🇬🇧 Auto-detect rules:
#     laragon → http://[project_name].test
#     xampp   → http://localhost/[project_name]
#     mamp    → http://localhost:8888/[project_name]
#     valet   → http://[project_name].test
#
#  🇯🇵 例 | 🇻🇳 Ví dụ | 🇬🇧 Examples:
#     PROXY_URL=http://localhost/my-project
#     PROXY_URL=http://mysite.local
#     PROXY_URL=http://localhost:8080
#
# PROXY_URL=
