# ─────────────────────────────────────────────
# Server Settings
# ─────────────────────────────────────────────

# Chọn loại Server của bạn (laragon hoặc xampp)
# Choose your server type (laragon or xampp)
SERVER_TYPE=laragon

# ─────────────────────────────────────────────
# Server Paths (Đường dẫn thư mục web)
# ─────────────────────────────────────────────

# Windows (Laragon)
LARAGON_WWW=D:\laragon\www

# Windows (XAMPP)
XAMPP_HTDOCS=C:\xampp\htdocs

# macOS (MAMP) — uncomment nếu dùng
# LARAGON_WWW=/Applications/MAMP/htdocs

# Linux — uncomment nếu dùng
# LARAGON_WWW=/var/www/html

# ─────────────────────────────────────────────
# Proxy URL (optional)
# ─────────────────────────────────────────────
# Nếu không đặt, sẽ tự sinh theo SERVER_TYPE:
#   laragon → http://[project_name].test
#   xampp   → http://localhost/[project_name]
#
# Đặt giá trị tuỳ chỉnh nếu dùng Docker, Valet, MAMP, v.v.
# PROXY_URL=http://myproject.local
